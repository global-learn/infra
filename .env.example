# ---------------------------------------------------------------------------
# Deploy env. Copy to .env and fill in real secrets:  cp .env.example .env
# Hostnames here are docker-compose SERVICE names (postgres, redis, minio),
# NOT localhost — the api container talks to them over the compose network.
# ---------------------------------------------------------------------------

# --- Postgres (used by the postgres container AND by DATABASE_URL below) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=global_learn
PGDATA=/var/lib/postgresql/data

# --- HTTPS / domain (Let's Encrypt) ---
# DOMAIN must point (DNS A-record) at this server (77.222.37.252). Used by nginx + Certbot.
DOMAIN=toooweee.online
# email for Let's Encrypt expiry notices
ACME_EMAIL=byprob03@gmail.com
# 1 = use Let's Encrypt staging (untrusted, for testing — avoids rate limits); 0 = real cert
CERTBOT_STAGING=0

# --- App ---
PORT=3000
DATABASE_URL=postgresql://postgres:change-me-strong-db-password@postgres:5432/global_learn

REDIS_IP=redis
REDIS_PORT=6379

# JWT secrets — MUST be at least 16 chars
JWT_ACCESS_SECRET=change-me-access-secret-min-16-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16-chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Mail (point at a real SMTP server in production)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=no-reply@globallearn.com

# Public URLs (your real domain over HTTPS)
APP_URL=https://toooweee.online
FRONTEND_URL=https://toooweee.online

# --- MinIO (object storage) ---
# Internal endpoint the API uses to read/write objects (compose service name).
MINIO_ENDPOINT=http://minio:9000
# Public base URL used to build & sign download links so images/files/certs
# open in the browser. Must be your real HTTPS domain — nginx proxies the
# /<bucket>/ path through to MinIO. Keep it in sync with DOMAIN above.
MINIO_PUBLIC_URL=https://toooweee.online
MINIO_ROOT_USER=change-me-minio-user
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_BUCKET_NAME=lms-bucket
MINIO_REGION=us-east-1

# --- Seed/test accounts (required by the env schema; used by `prisma db seed`) ---
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=change-me-admin-password
TEST_EMPLOYEE_EMAIL=employee@example.com
TEST_EMPLOYEE_PASSWORD=change-me-employee-password
